{
  "name": "clutterstock-frontend",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "react-router build",
    "dev": "react-router dev",
    "start": "react-router-serve ./build/server/index.js",
    "typecheck": "react-router typegen && tsc",
    "lint": "eslint . --report-unused-disable-directives --max-warnings 0",
    "lint:fix": "eslint . --fix",
    "lint:ci": "eslint . --report-unused-disable-directives --format json",
    "openapi-typescript": "openapi-typescript ../backend/src/Api/openapi.json --enum -o ./app/api/types.ts",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "coverage": "vitest --coverage",
    "coverage:ci": "vitest run --coverage",
    "stryker": "react-router typegen && stryker run",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "load": "artillery run --output load-report.json load/clutterstock.yml",
    "load:report": "artillery report load-report.json"
  },
  "dependencies": {
    "@opentelemetry/api": "1.9.1",
    "@opentelemetry/auto-instrumentations-node": "0.74.0",
    "@opentelemetry/auto-instrumentations-web": "0.61.0",
    "@opentelemetry/context-zone": "2.7.1",
    "@opentelemetry/exporter-logs-otlp-http": "0.216.0",
    "@opentelemetry/exporter-metrics-otlp-http": "0.216.0",
    "@opentelemetry/exporter-trace-otlp-http": "0.216.0",
    "@opentelemetry/instrumentation": "0.216.0",
    "@opentelemetry/resources": "2.7.1",
    "@opentelemetry/sdk-logs": "0.216.0",
    "@opentelemetry/sdk-metrics": "2.7.1",
    "@opentelemetry/sdk-node": "0.216.0",
    "@opentelemetry/sdk-trace-base": "2.7.1",
    "@opentelemetry/sdk-trace-web": "2.7.1",
    "@opentelemetry/semantic-conventions": "1.40.0",
    "@react-router/node": "7.14.2",
    "@react-router/serve": "7.14.2",
    "isbot": "5.1.39",
    "oidc-client-ts": "3.5.0",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "react-router": "7.14.2",
    "redis": "5.12.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.3",
    "@playwright/test": "1.60.0",
    "artillery": "2.0.31",
    "@react-router/dev": "7.14.2",
    "@stryker-mutator/core": "9.6.1",
    "@stryker-mutator/typescript-checker": "9.6.1",
    "@stryker-mutator/vitest-runner": "9.6.1",
    "@tailwindcss/vite": "4.3.0",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@types/node": "25.8.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitest/coverage-v8": "4.1.5",
    "allure": "3.8.2",
    "allure-playwright": "3.7.1",
    "dotenv": "17.4.2",
    "eslint": "^9.39.3",
    "eslint-formatter-compact": "^9.0.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "jsdom": "29.1.1",
    "lighthouse": "13.3.0",
    "monocart-reporter": "2.11.2",
    "msw": "2.14.2",
    "openapi-msw": "2.0.0",
    "openapi-typescript": "7.13.0",
    "otpauth": "9.5.1",
    "playwright-lighthouse": "4.0.0",
    "tailwindcss": "4.3.0",
    "typescript": "5.9.3",
    "typescript-eslint": "^8.57.0",
    "vite": "8.0.10",
    "vitest": "4.1.5"
  }
}
